{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Glowberry",
    "version": "0.1.0",
    "identifier": "com.glowberry.glowberry",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "Glowberry",
                "width": 360,
                "height": 460,
                "resizable": false,
                "decorations": true,
                "titleBarStyle": "Overlay",
                "visible": false
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "macOS": {
            "dmg": {
                "background": "../assets/dmg-background.png"
            }
        },
        "icon": ["../assets/glowberry.png", "../assets/mac.icns", "../assets/glowberry.ico"]
    }
}
