{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Glowberry",
    "version": "0.1.0",
    "identifier": "com.glowberry.glowberry",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "Glowberry",
                "width": 360,
                "height": 460,
                "resizable": false,
                "decorations": true,
                "titleBarStyle": "Transparent",
                "backgroundColor": "#0e0f14",
                "visible": false
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "createUpdaterArtifacts": true,
        "macOS": {
            "entitlements": "entitlements.plist",
            "dmg": {
                "background": "../assets/dmg-background.png"
            }
        },
        "icon": ["../assets/glowberry.png", "../assets/mac.icns", "../assets/glowberry.ico"]
    },
    "plugins": {
        "updater": {
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlGMkFENjI0NEI1QjBCMUMKUldRY0MxdExKTllxbjJoYm5vVjEzNnRqOWVkQjR0OHhlUTFGN1RrRUh5dEN5aHFYTU9HZzMrVHYK",
            "windows": {
                "installMode": "passive"
            },
            "endpoints": [
                "https://github.com/matejstastny/glowberry/releases/latest/download/latest.json"
            ]
        }
    }
}
